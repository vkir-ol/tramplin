# ============================================================
# Переменные окружения для платформы «Трамплин»
# Скопируйте в .env и заполните своими значениями
# ВАЖНО: .env НЕ ДОЛЖЕН попадать в git-репозиторий!
# ============================================================

# --- База данных ---
DB_NAME=tramplin
DB_USER=tramplin_user
DB_PASSWORD=tramplin_secret

# --- JWT ---
JWT_SECRET=my-super-secret-key-that-is-at-least-256-bits-long-for-hmac-sha256!!
JWT_EXPIRATION_MS=86400000

# --- Сервер ---
SERVER_PORT=8080
